import { useCallback, useMemo, useState } from 'react';
import {
  ActivityIndicator,
  KeyboardAvoidingView,
  Platform,
  RefreshControl,
  ScrollView,
  StyleSheet,
  Text,
  TextInput,
  TouchableOpacity,
  View,
} from 'react-native';
import { useFocusEffect, useLocalSearchParams, useRouter } from 'expo-router';
import { SafeAreaView, useSafeAreaInsets } from 'react-native-safe-area-context';

import AppHeader, {
  APP_HEADER_HEIGHT,
  APP_HEADER_TOP_PADDING,
} from '../src/ui/app-header';
import MenuSheet from '../src/ui/menu-sheet';
import SubmenuHeader from '../src/ui/submenu-header';
import { colors, layout, radius } from '../src/theme/tokens';
import { useNotice } from '../src/notice/notice-provider';
import { TRX_TOKEN_ID } from '../src/services/tron/api';
import { getSendAssetDraft, sendAssetTransfer } from '../src/services/wallet/send';
import { openInAppBrowser } from '../src/utils/open-in-app-browser';

function isValidTronAddress(value: string) {
  return /^T[1-9A-HJ-NP-Za-km-z]{33}$/.test(String(value || '').trim());
}

function shortTx(value: string) {
  const safe = String(value || '').trim();
  if (safe.length < 14) return safe;
  return `${safe.slice(0, 8)}...${safe.slice(-6)}`;
}

export default function SendScreen() {
  const router = useRouter();
  const notice = useNotice();
  const insets = useSafeAreaInsets();
  const params = useLocalSearchParams<{ tokenId?: string }>();

  const [menuOpen, setMenuOpen] = useState(false);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [sending, setSending] = useState(false);
  const [errorText, setErrorText] = useState('');
  const [draft, setDraft] = useState<Awaited<ReturnType<typeof getSendAssetDraft>> | null>(null);
  const [recipient, setRecipient] = useState('');
  const [amount, setAmount] = useState('');

  const tokenId =
    typeof params.tokenId === 'string'
      ? params.tokenId
      : Array.isArray(params.tokenId)
        ? params.tokenId[0]
        : TRX_TOKEN_ID;

  const contentBottomInset = 44 + Math.max(insets.bottom, 6);

  const load = useCallback(async () => {
    try {
      setLoading(true);
      setErrorText('');

      const nextDraft = await getSendAssetDraft(tokenId);
      setDraft(nextDraft);
    } catch (error) {
      console.error(error);
      setDraft(null);
      setErrorText(error instanceof Error ? error.message : 'Failed to load send screen.');
      notice.showErrorNotice('Failed to load send screen.', 2400);
    } finally {
      setLoading(false);
    }
  }, [notice, tokenId]);

  useFocusEffect(
    useCallback(() => {
      void load();
    }, [load])
  );

  const handleRefresh = useCallback(async () => {
    try {
      setRefreshing(true);
      await load();
    } finally {
      setRefreshing(false);
    }
  }, [load]);

  const tokenLabel = useMemo(() => {
    return draft?.token?.symbol || draft?.token?.name || 'TOKEN';
  }, [draft?.token?.name, draft?.token?.symbol]);

  const handleSetMax = useCallback(() => {
    if (!draft?.spendableAmount) return;
    setAmount(draft.spendableAmount);
  }, [draft?.spendableAmount]);

  const handleSend = useCallback(async () => {
    if (!draft) return;

    const toAddress = recipient.trim();
    const safeAmount = amount.trim();

    if (!isValidTronAddress(toAddress)) {
      notice.showErrorNotice('Enter a valid TRON address.', 2200);
      return;
    }

    if (!safeAmount) {
      notice.showErrorNotice('Enter amount.', 2200);
      return;
    }

    if (draft.wallet.kind === 'watch-only') {
      notice.showErrorNotice(
        'Watch-only wallet cannot sign or send transactions.',
        2600
      );
      return;
    }

    try {
      setSending(true);

      const result = await sendAssetTransfer({
        tokenId: draft.token.tokenId,
        toAddress,
        amount: safeAmount,
      });

      notice.showSuccessNotice(
        `${tokenLabel} sent. ${shortTx(result.txId)}`,
        3200
      );

      setAmount('');
      setRecipient('');

      try {
        await openInAppBrowser(router, result.explorerUrl);
      } catch (browserError) {
        console.error(browserError);
      }

      await load();
    } catch (error) {
      console.error(error);
      notice.showErrorNotice(
        error instanceof Error ? error.message : 'Failed to send transaction.',
        3200
      );
    } finally {
      setSending(false);
    }
  }, [amount, draft, load, notice, recipient, router, tokenLabel]);

  return (
    <SafeAreaView style={styles.safe} edges={['top', 'bottom']}>
      <View style={styles.screen}>
        <View style={styles.headerSlot}>
          <AppHeader
            onMenuPress={() => setMenuOpen(true)}
            onSearchPress={() => router.push('/search-lab')}
          />
        </View>

        <KeyboardAvoidingView
          style={styles.keyboard}
          behavior={Platform.OS === 'ios' ? 'padding' : undefined}
        >
          <ScrollView
            style={styles.scroll}
            contentContainerStyle={[styles.content, { paddingBottom: contentBottomInset }]}
            showsVerticalScrollIndicator={false}
            refreshControl={
              <RefreshControl
                refreshing={refreshing}
                onRefresh={handleRefresh}
                tintColor={colors.accent}
                colors={[colors.accent]}
                progressBackgroundColor={colors.bg}
              />
            }
          >
            <SubmenuHeader title="SEND" onBack={() => router.back()} />

            {loading ? (
              <View style={styles.loadingWrap}>
                <ActivityIndicator color={colors.accent} />
              </View>
            ) : draft ? (
              <>
                <View style={styles.card}>
                  <Text style={styles.label}>From wallet</Text>
                  <Text style={styles.value}>{draft.wallet.name}</Text>
                  <Text style={styles.subvalue}>{draft.wallet.address}</Text>

                  <View style={styles.divider} />

                  <Text style={styles.label}>Asset</Text>
                  <Text style={styles.value}>{draft.token.name}</Text>
                  <Text style={styles.subvalue}>
                    {draft.token.symbol} · Balance: {draft.token.balanceFormatted}
                  </Text>
                </View>

                <View style={styles.formCard}>
                  <Text style={styles.inputLabel}>Recipient</Text>
                  <TextInput
                    value={recipient}
                    onChangeText={setRecipient}
                    placeholder="TRON address"
                    placeholderTextColor={colors.textDim}
                    style={styles.input}
                    autoCapitalize="none"
                    autoCorrect={false}
                  />

                  <View style={styles.amountHeaderRow}>
                    <Text style={styles.inputLabel}>Amount</Text>
                    <TouchableOpacity
                      activeOpacity={0.85}
                      onPress={handleSetMax}
                      style={styles.maxButton}
                    >
                      <Text style={styles.maxButtonText}>Max</Text>
                    </TouchableOpacity>
                  </View>

                  <TextInput
                    value={amount}
                    onChangeText={setAmount}
                    placeholder={`0 ${tokenLabel}`}
                    placeholderTextColor={colors.textDim}
                    style={styles.input}
                    autoCapitalize="none"
                    autoCorrect={false}
                    keyboardType="decimal-pad"
                  />

                  <Text style={styles.hint}>
                    {draft.token.tokenId === TRX_TOKEN_ID
                      ? 'Native TRX transfer.'
                      : 'TRC20 transfer. Network may consume energy or burn TRX if energy is insufficient.'}
                  </Text>

                  <TouchableOpacity
                    activeOpacity={0.9}
                    style={[styles.sendButton, sending && styles.sendButtonDisabled]}
                    onPress={() => void handleSend()}
                    disabled={sending}
                  >
                    {sending ? (
                      <ActivityIndicator color={colors.bg} />
                    ) : (
                      <Text style={styles.sendButtonText}>Send {tokenLabel}</Text>
                    )}
                  </TouchableOpacity>
                </View>
              </>
            ) : (
              <View style={styles.errorWrap}>
                <Text style={styles.errorText}>{errorText || 'Unable to load send screen.'}</Text>
              </View>
            )}
          </ScrollView>
        </KeyboardAvoidingView>

        <MenuSheet open={menuOpen} onClose={() => setMenuOpen(false)} />
      </View>
    </SafeAreaView>
  );
}

