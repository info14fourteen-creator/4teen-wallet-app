import { useCallback, useState } from 'react';
import {
  RefreshControl,
  ScrollView,
  StyleSheet,
  Text,
  TouchableOpacity,
  View,
} from 'react-native';
import { SafeAreaView } from 'react-native-safe-area-context';

import { NavigationChrome, useNavigationInsets } from '../src/ui/navigation';

import { colors, layout, radius } from '../src/theme/tokens';
import { ui } from '../src/theme/ui';

const LOREM = [
  'This page will grow over time.',
  'Store approved section names here.',
  'Store spacing notes here.',
  'Store header and footer behavior rules here.',
  'Store card patterns and composition rules here.',
  'Store naming for shared UI blocks here.',
  'Store do and do not rules for new pages here.',
  'This file is the baseline before scaling the rest of the app.',
];

export default function UiShellLab() {
  const [refreshing, setRefreshing] = useState(false);
  const [menuOpen, setMenuOpen] = useState(false);

  const navInsets = useNavigationInsets({
    topExtra: 14,
    bottomExtra: 20,
  });

  const handleRefresh = useCallback(async () => {
    setRefreshing(true);
    await new Promise((resolve) => setTimeout(resolve, 700));
    setRefreshing(false);
  }, []);

  return (
    <SafeAreaView style={styles.safe} edges={['left', 'right']}>
      <View style={styles.screen}>
        <ScrollView
          style={styles.scroll}
          contentContainerStyle={[
            styles.content,
            {
              paddingTop: navInsets.top,
              paddingBottom: navInsets.bottom,
            },
          ]}
          showsVerticalScrollIndicator={false}
          bounces
          refreshControl={
            <RefreshControl
              refreshing={refreshing}
              onRefresh={handleRefresh}
              tintColor={colors.accent}
              colors={[colors.accent]}
              progressBackgroundColor={colors.bg}
            />
          }
        >
          <View style={styles.hero}>
            <Text style={ui.sectionEyebrow}>UI SHELL LAB</Text>
            <Text style={styles.title}>Navigation and layout reference</Text>
            <Text style={styles.lead}>
              This screen is the reference template for future pages. We keep navigation rules, spacing rules, and UI naming patterns here so new screens can be assembled without breaking layout rhythm.
            </Text>
          </View>

          <View style={styles.card}>
            <Text style={ui.sectionEyebrow}>BLOCK 01</Text>
            <Text style={styles.cardTitle}>Top and bottom navigation mounting</Text>
            <Text style={styles.cardText}>
              Use NavigationChrome as the only top and bottom shell layer. Screen content must not create its own fake safe-area offsets for header or footer. Content spacing should come from useNavigationInsets so the page stays clean and reusable.
            </Text>
          </View>

          <View style={styles.card}>
            <Text style={ui.sectionEyebrow}>BLOCK 02</Text>
            <Text style={styles.cardTitle}>Layout spacing rules</Text>
            <Text style={styles.cardText}>
              Top page content starts below navigationInsets.top. Bottom page content ends above navigationInsets.bottom. Internal cards use the shared screen padding and should not guess header or footer height manually.
            </Text>

            <TouchableOpacity activeOpacity={0.9} style={styles.reloadButton} onPress={handleRefresh}>
              <Text style={styles.reloadButtonText}>Reference action</Text>
            </TouchableOpacity>
          </View>

          <View style={styles.card}>
            <Text style={ui.sectionEyebrow}>BLOCK 03</Text>
            <Text style={styles.cardTitle}>Style and naming registry</Text>
            <View style={styles.loremList}>
              {LOREM.concat(LOREM).map((item, index) => (
                <Text key={`${index}-${item.slice(0, 16)}`} style={styles.loremText}>
                  {item}
                </Text>
              ))}
            </View>
          </View>
        </ScrollView>

        <NavigationChrome
          menuOpen={menuOpen}
          onOpenMenu={() => setMenuOpen(true)}
          onCloseMenu={() => setMenuOpen(false)}
          forceFooterVisible
        />
      </View>
    </SafeAreaView>
  );
}

const styles = StyleSheet.create({
  safe: {
    flex: 1,
    backgroundColor: colors.bg,
  },

  screen: {
    flex: 1,
    backgroundColor: colors.bg,
  },

  scroll: {
    flex: 1,
    backgroundColor: colors.bg,
  },

  content: {
    paddingHorizontal: layout.screenPaddingX,
    gap: 18,
  },

  hero: {
    gap: 10,
  },

  title: {
    ...ui.titleLg,
  },

  lead: {
    ...ui.body,
  },

  card: {
    borderRadius: radius.md,
    borderWidth: 1,
    borderColor: colors.lineSoft,
    backgroundColor: colors.surfaceSoft,
    paddingHorizontal: 16,
    paddingVertical: 16,
    gap: 10,
  },

  cardTitle: {
    ...ui.titleSm,
  },

  cardText: {
    ...ui.body,
  },

  loremList: {
    gap: 12,
  },

  loremText: {
    ...ui.body,
    color: colors.textSoft,
  },

  reloadButton: {
    minHeight: 52,
    borderRadius: radius.sm,
    backgroundColor: colors.accent,
    alignItems: 'center',
    justifyContent: 'center',
    paddingHorizontal: 16,
    marginTop: 6,
  },

  reloadButtonText: {
    color: colors.bg,
    fontSize: 14,
    lineHeight: 18,
    fontFamily: 'Sora_700Bold',
  },
});
