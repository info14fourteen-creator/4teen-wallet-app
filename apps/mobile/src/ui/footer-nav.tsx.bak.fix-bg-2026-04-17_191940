import { useEffect, useMemo, useState } from 'react';
import {
  Image,
  LayoutChangeEvent,
  StyleSheet,
  Text,
  TouchableOpacity,
  View,
  ViewStyle,
} from 'react-native';
import { usePathname, useRouter } from 'expo-router';
import Svg, { Defs, Line, LinearGradient, Stop } from 'react-native-svg';
import { useSafeAreaInsets } from 'react-native-safe-area-context';

import { colors } from '../theme/tokens';
import { useWalletSession } from '../wallet/wallet-session';

import AirdropIcon from '../../assets/icons/footer/airdrop_footer.svg';
import BuyIcon from '../../assets/icons/footer/buy_footer.svg';
import SwapIcon from '../../assets/icons/footer/swap_footer.svg';
import AmbassadorIcon from '../../assets/icons/footer/ambassador_footer.svg';

export const FOOTER_NAV_HEIGHT = 74;
export const FOOTER_NAV_RESERVED_SPACE = 60;

const HIDDEN_ROUTES = new Set([
  '/',
  '/index',
  '/unlock',
  '/create-wallet',
  '/create-passcode',
  '/confirm-passcode',
  '/enable-biometrics',
  '/ui-shell-lab',
]);

type FooterNavProps = {
  forceVisible?: boolean;
  style?: ViewStyle;
};

type FooterButtonProps = {
  Icon: any;
  label: string;
  onPress?: () => void;
};

export default function FooterNav({ forceVisible = false, style }: FooterNavProps) {
  const router = useRouter();
  const pathname = usePathname();
  const insets = useSafeAreaInsets();
  const { hasWallet, footerTickerItems } = useWalletSession();

  const [barWidth, setBarWidth] = useState(0);
  const [tickerIndex, setTickerIndex] = useState(0);

  useEffect(() => {
    if (!footerTickerItems.length) return;

    const timer = setInterval(() => {
      setTickerIndex((prev) => (prev + 1) % footerTickerItems.length);
    }, 2600);

    return () => clearInterval(timer);
  }, [footerTickerItems]);

  const tickerItem = useMemo(() => {
    if (!footerTickerItems.length) return null;
    return footerTickerItems[tickerIndex % footerTickerItems.length] || null;
  }, [footerTickerItems, tickerIndex]);

  if (!forceVisible && HIDDEN_ROUTES.has(pathname)) return null;

  const handleLayout = (event: LayoutChangeEvent) => {
    setBarWidth(event.nativeEvent.layout.width);
  };

  const circleSize = 50;
  const circleRadius = circleSize / 2;
  const lineY = 24;
  const linePadding = 18;
  const lineOverlap = 8;

  const leftLineStart = barWidth / 2 - circleRadius + lineOverlap;
  const rightLineStart = barWidth / 2 + circleRadius - lineOverlap;

  const onCenterPress = () => {
    router.replace(hasWallet ? '/home' : '/create-wallet');
  };

  return (
    <View pointerEvents="box-none" style={[styles.root, style]}>
      <View style={[styles.host, { paddingBottom: Math.max(insets.bottom, 1) }]}>
        <View style={styles.shell} onLayout={handleLayout}>
          <View style={styles.topFill} />

          {barWidth > 0 ? (
            <Svg style={styles.linesSvg} width={barWidth} height={FOOTER_NAV_HEIGHT}>
              <Defs>
                <LinearGradient id="fadeLeft" x1="100%" y1="0%" x2="0%" y2="0%">
                  <Stop offset="0%" stopColor={colors.accent} stopOpacity="0.95" />
                  <Stop offset="100%" stopColor={colors.accent} stopOpacity="0" />
                </LinearGradient>
                <LinearGradient id="fadeRight" x1="0%" y1="0%" x2="100%" y2="0%">
                  <Stop offset="0%" stopColor={colors.accent} stopOpacity="0.95" />
                  <Stop offset="100%" stopColor={colors.accent} stopOpacity="0" />
                </LinearGradient>
              </Defs>

              <Line
                x1={leftLineStart}
                y1={lineY}
                x2={linePadding}
                y2={lineY}
                stroke="url(#fadeLeft)"
                strokeWidth="1.5"
                strokeLinecap="round"
              />
              <Line
                x1={rightLineStart}
                y1={lineY}
                x2={barWidth - linePadding}
                y2={lineY}
                stroke="url(#fadeRight)"
                strokeWidth="1.5"
                strokeLinecap="round"
              />
            </Svg>
          ) : null}

          <View style={styles.row}>
            <FooterButton
              Icon={AirdropIcon}
              label="AIRDROP"
              onPress={() => router.push('/airdrop' as any)}
            />
            <FooterButton
              Icon={BuyIcon}
              label="BUY"
              onPress={() => router.push('/buy' as any)}
            />

            <TouchableOpacity activeOpacity={0.9} style={styles.centerButton} onPress={onCenterPress}>
              <View style={styles.circle}>
                {tickerItem?.logoUri ? (
                  <Image source={{ uri: tickerItem.logoUri }} style={styles.logo} />
                ) : (
                  <View style={[styles.dot, hasWallet ? styles.dotOnline : styles.dotOffline]} />
                )}
              </View>

              <Text style={styles.centerLabel}>
                {tickerItem?.balanceLabel || 'WALLET'}
              </Text>
            </TouchableOpacity>

            <FooterButton
              Icon={SwapIcon}
              label="SWAP"
              onPress={() => router.push('/swap' as any)}
            />
            <FooterButton
              Icon={AmbassadorIcon}
              label="AMBASSADOR"
              onPress={() => router.push('/ambassador' as any)}
            />
          </View>
        </View>
      </View>
    </View>
  );
}

function FooterButton({ Icon, label, onPress }: FooterButtonProps) {
  return (
    <TouchableOpacity activeOpacity={0.8} style={styles.button} onPress={onPress}>
      <Icon width={28} height={28} />
      <Text style={styles.label}>{label}</Text>
    </TouchableOpacity>
  );
}

const styles = StyleSheet.create({
  root: {
    ...StyleSheet.absoluteFillObject,
  },

  host: {
    position: 'absolute',
    left: 0,
    right: 0,
    bottom: -5,
    height: FOOTER_NAV_RESERVED_SPACE,
    backgroundColor: colors.bg,
    justifyContent: 'flex-end',
  },

  shell: {
    height: FOOTER_NAV_HEIGHT,
    justifyContent: 'flex-end',
    position: 'relative',
    backgroundColor: colors.bg,
  },

  topFill: {
    position: 'absolute',
    top: -10,
    left: 0,
    right: 0,
    height: 18,
    backgroundColor: colors.bg,
  },

  linesSvg: {
    position: 'absolute',
    top: 0,
    left: 0,
    right: 0,
  },

  row: {
    flexDirection: 'row',
    alignItems: 'flex-end',
    justifyContent: 'center',
    paddingHorizontal: 8,
    paddingBottom: 1,
  },

  button: {
    flex: 1,
    alignItems: 'center',
    justifyContent: 'flex-end',
    paddingHorizontal: 2,
  },

  label: {
    marginTop: 4,
    color: colors.white,
    fontSize: 9,
    lineHeight: 11,
    fontFamily: 'Sora_600SemiBold',
    textAlign: 'center',
  },

  centerButton: {
    flex: 1.2,
    alignItems: 'center',
    justifyContent: 'flex-end',
    paddingHorizontal: 4,
    marginTop: 8,
  },

  circle: {
    width: 50,
    height: 50,
    borderRadius: 25,
    borderWidth: 1.5,
    borderColor: colors.accent,
    alignItems: 'center',
    justifyContent: 'center',
    backgroundColor: colors.bg,
  },

  dot: {
    width: 12,
    height: 12,
    borderRadius: 6,
  },

  dotOnline: {
    backgroundColor: colors.green,
    shadowColor: colors.green,
    shadowRadius: 10,
    shadowOpacity: 0.8,
  },

  dotOffline: {
    backgroundColor: colors.red,
    shadowColor: colors.red,
    shadowRadius: 10,
    shadowOpacity: 0.8,
  },

  logo: {
    width: 28,
    height: 28,
    resizeMode: 'contain',
  },

  centerLabel: {
    marginTop: 4,
    color: colors.accent,
    fontSize: 9,
    lineHeight: 11,
    fontFamily: 'Sora_600SemiBold',
    textAlign: 'center',
  },
});
