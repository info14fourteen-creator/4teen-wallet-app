{
  "expo": {
    "name": "4TEEN Wallet",
    "slug": "4teen-wallet",
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow 4TEEN Wallet to use Face ID."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow 4TEEN Wallet to access your camera to scan QR codes."
        }
      ],
      "expo-secure-store"
    ],
    "android": {
      "softwareKeyboardLayoutMode": "resize"
    },
    "scheme": "fourteenwallet"
  }
}
